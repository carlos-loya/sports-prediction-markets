# Kalshi API credentials
KALSHI_API_KEY_ID=your_api_key_id_here
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem

# Optional: Slack webhook for edge alerts
SLACK_WEBHOOK_URL=

# Optional: Telegram bot for real-time alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Environment
ENVIRONMENT=dev
